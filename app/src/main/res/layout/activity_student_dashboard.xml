<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background">

    <!-- 🌙 Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#22000000" />

    <!-- Sticky Bottom Navigation Bar (Visual only, exactly like image) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:elevation="10dp"
        android:background="#99000000">
        
        <ImageView
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:src="@drawable/ic_home"
            android:padding="16dp"
            android:contentDescription="Home"/>
            
        <ImageView
            android:id="@+id/btnNavStar"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:src="@drawable/ic_progress"
            android:padding="12dp"
            android:contentDescription="Progress"/>
            
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:src="@drawable/ic_settings"
            android:padding="16dp"
            android:contentDescription="Settings"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/dashScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_green"
                android:elevation="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="12dp">
                    <ImageView
                        android:id="@+id/dashAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/avatar_lion"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/student_dashboard_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:id="@+id/dashGreetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/student_dashboard_greeting"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/dashClassText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class 1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:layout_marginBottom="24dp"/>

            <!-- Dynamic Subjects Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/student_dashboard_subjects"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:shadowColor="#000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:layout_marginBottom="8dp"/>

            <!-- Dynamic Subject Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSubjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

            <!-- Learning Tools Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/student_dashboard_tools"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:shadowColor="#000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:layout_marginBottom="8dp"/>

            <!-- Grid Layout representing the static tool cards -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true"
                android:alignmentMode="alignBounds">

                <!-- Games -->
                <LinearLayout
                    android:id="@+id/cardGames"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_gradient_purple"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_games"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="🎮"
                        android:textSize="50sp"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_games_desc"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Quizzes -->
                <LinearLayout
                    android:id="@+id/cardQuizzes"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_gradient_dark_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_quizzes"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="📝"
                        android:textSize="50sp"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_quizzes_desc"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Notes -->
                <LinearLayout
                    android:id="@+id/cardNotes"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_gradient_orange"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_notes"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="📄"
                        android:textSize="50sp"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_notes_desc"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- AI Tutor -->
                <LinearLayout
                    android:id="@+id/cardAIChat"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_gradient_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_ai"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_cute_robot"
                        android:contentDescription="AI Tutor"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tool_ai_desc"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Communication Skills (Class 5-10 only) -->
                <LinearLayout
                    android:id="@+id/cardCommunicationSkills"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_gradient_light_green"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Communication"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="🎤"
                        android:textSize="50sp"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speaking Skills"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

            </GridLayout>

            <!-- HIDDEN FIELDS REQUIRED FOR LOGIC -->
            <Spinner android:id="@+id/spinnerSubjectFilter" android:layout_width="0dp" android:layout_height="0dp" android:entries="@array/subject_options" android:visibility="gone"/>
            <Spinner android:id="@+id/spinnerUnitFilter" android:layout_width="0dp" android:layout_height="0dp" android:entries="@array/unit_options" android:visibility="gone"/>
            <ProgressBar android:id="@+id/pbOverallProgress" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" style="?android:attr/progressBarStyleHorizontal"/>
            <TextView android:id="@+id/tvStreakValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvPoints" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_orange"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp"
                android:elevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tvRecentSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_uploads_section"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:shadowColor="#000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        android:layout_marginBottom="12dp"/>
                        
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"/>
                        
                    <TextView
                        android:id="@+id/tvEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_uploads_empty"
                        android:textAlignment="center"
                        android:textSize="16sp"
                        android:textColor="#FFF"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
