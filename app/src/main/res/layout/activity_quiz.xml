<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0">

    <com.tannu.edureach.AnimatedBackgroundView
        android:id="@+id/animatedBgQuiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout 
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvQuizTitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Loading Quiz..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>
            
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:drawableStart="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="8dp"/>
        </LinearLayout>
        
        <ProgressBar
            android:id="@+id/pbQuizProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvQuestionProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Question 1/10"
            android:textSize="14sp"
            android:textColor="#FF9800"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvQuestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wait while the question loads..."
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <LinearLayout
            android:id="@+id/optionsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <!-- Options dynamically inflated -> Just use buttons directly for ease of access -->
            <Button
                android:id="@+id/btnOption1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFB74D"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnOption2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFB74D"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnOption3"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFB74D"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnOption4"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="#FFB74D"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:text="Previous"
                android:backgroundTint="#9E9E9E"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:text="Next"
                android:backgroundTint="#2196F3"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <Button
            android:id="@+id/btnSubmitQuiz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Submit Quiz"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</FrameLayout>
