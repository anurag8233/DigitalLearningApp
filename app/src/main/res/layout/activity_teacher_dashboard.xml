<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background">

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#22000000" />

    <!-- Sticky Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:elevation="10dp"
        android:background="#99000000">
        

            
        <ImageView
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:src="@drawable/ic_profile"
            android:padding="16dp"
            android:contentDescription="Profile" />

        <ImageView
            android:id="@+id/btnNavLogout"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:src="@drawable/ic_logout"
            android:padding="16dp"
            android:contentDescription="Logout" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_green"
                android:elevation="6dp"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="12dp">
                    <ImageView
                        android:id="@+id/dashAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/avatar_lion"
                        android:scaleType="centerCrop"
                        android:contentDescription="Avatar" />
                </androidx.cardview.widget.CardView>
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTeacherName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/teacher_dashboard_title"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:id="@+id/tvTeacherSubject"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/teacher_subject_label"
                        android:textSize="14sp"
                        android:textColor="#E0E0E0"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnRefreshContent"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_refresh"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:contentDescription="Refresh"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnAddContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_content"
                android:background="@drawable/bg_gradient_blue"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"
                android:elevation="4dp"/>

            <Button
                android:id="@+id/btnAddGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_game"
                android:background="@drawable/bg_gradient_light_green"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"/>

            <TextView
                android:id="@+id/tvSubjectsSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subjects"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:layout_marginBottom="8dp"/>

            <!-- Subject Cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTeacherSubjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvUploadedSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teacher_uploaded_section"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:layout_marginBottom="16dp"/>

            <!-- Content List by Class -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTeacherContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_book_illustration"
                    android:alpha="0.8"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/teacher_empty_state_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/teacher_empty_state_desc"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
